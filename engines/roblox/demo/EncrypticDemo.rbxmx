<?xml version="1.0" encoding="utf-8"?>
<roblox version="4">
  <Item class="Model" referent="RBX1">
    <Properties>
      <string name="Name">EncrypticDemo</string>
    </Properties>
    <Item class="Folder" referent="RBX2">
